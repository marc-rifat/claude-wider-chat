{
  "manifest_version": 3,
  "name": "Claude Wider Chat",
  "description": "Makes the Claude.ai chatbox wider and adjustable with a draggable slider.",
  "version": "1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
